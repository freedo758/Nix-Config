import QtQuick
import Quickshell

QtObject {
    readonly property string homeDir: Quickshell.env("HOME")

    property string wallpaperDir: "/home/YOUR_USERNAME/Wallpapers/Wallpapers"
    readonly property string cacheDir: "/home/YOUR_USERNAME/.cache/wallpaper_picker"
    readonly property string thumbDir: "/home/YOUR_USERNAME/.cache/wallpaper_picker/thumbs"

    property bool uiAnimationsEnabled: true
    property real uiAnimationScale: 1.0

    property string wallpaperTransitionType: "random"
    property real wallpaperTransitionDuration: 0.6
    property int wallpaperTransitionFps: 60

    property int closeDelayMs: 120
    property int scrollThrottleMs: 150
    property int filterAnimationMs: 800
    property int itemAnimationMs: 500

    property bool enableDynamicColors: true
    property bool enableMatugen: true
    property bool enableHyprReload: true
    property bool enableWaybarReload: true
    property bool enableKittyReload: true
    property bool enableCavaReload: true
    property bool enableSwayncReload: true
    property bool enableSwayosdReload: true

    property string hyprColorsPath: "/home/YOUR_USERNAME/.config/hypr/colors.conf"
    property string waybarColorsPath: "/home/YOUR_USERNAME/.config/waybar/colors.css"
    property string waybarLaunchPath: "/home/YOUR_USERNAME/.config/waybar/launch.sh"
    property string kittySignalProcess: ".kitty-wrapped"

    property string extraReloadCommand: ""
}
